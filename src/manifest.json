{
  "manifest_version": 3,
  "name": "Misskey Build Page Patcher",
  "version": "0.1.0",
  "description": "Applies CSS/JS patches to built Misskey pages without modifying the Misskey build output.",
  "permissions": [
    "storage",
    "activeTab",
    "userScripts"
  ],
  "minimum_chrome_version": "120",
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Misskey Patcher",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "page-bridge.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "patch.css"
      ],
      "run_at": "document_start"
    }
  ]
}
